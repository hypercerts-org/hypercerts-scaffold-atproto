# ===========================================
# Playwright Test Environment Configuration
# ===========================================
# Copy this file to tests/.env.test and fill in your test credentials
# IMPORTANT: tests/.env.test is gitignored - never commit credentials!

# -----------------------------
# Application URL
# -----------------------------
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000

# -----------------------------
# Test Account Credentials
# -----------------------------
# ATProto handle for test user (e.g., newuser.climateai.org)
TEST_USER_HANDLE=your-test-user.climateai.org

# Password for the test account
TEST_USER_PASSWORD=your-test-password

# DID of the test user (will be auto-discovered after first login)
# Example: did:plc:abc123xyz...
TEST_USER_DID=

# -----------------------------
# ATProto Configuration
# -----------------------------
# Personal Data Server (PDS) URL
NEXT_PUBLIC_PDS_URL=https://pds-eu-west4.test.certified.app

# -----------------------------
# Redis Configuration
# -----------------------------
# Redis must be running for OAuth session storage
# For local development:
# docker run -d -p 6379:6379 redis:alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------
# ATProto Authentication
# -----------------------------
# Private JSON Web Key (JWK) for OAuth authentication
# Copy from your main .env file
# Generate using: pnpm generate-jwk
ATPROTO_JWK_PRIVATE={"keys":[{"kty":"EC","x":"...","y":"...","crv":"P-256","d":"...","kid":"...","alg":"ES256"}]}

# -----------------------------
# Test Timing Configuration (Optional)
# -----------------------------
# Global test timeout in milliseconds
TEST_TIMEOUT=60000

# Number of retries for failed tests
TEST_RETRY_COUNT=2

# Timeout for creating hypercerts (may take longer due to uploads)
TEST_CREATE_HYPERCERT_TIMEOUT=90000
